<?xml version="1.0" encoding="utf-8"?>
<!--
  Fallback launcher icon for API 24-25 (no adaptive-icon support). A LayerList composes the
  same background + foreground as a single drawable. Vector drawables are valid app icons
  since API 21, so this avoids shipping density-specific PNGs.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@drawable/ic_launcher_background" />
    <item android:drawable="@drawable/ic_launcher_foreground" />
</layer-list>
